# {{APP_DISPLAY_NAME}} — Environment Variables
# Copy to .env and fill in values

# === Database ===
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/{{APP_SLUG_UNDERSCORE}}
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/{{APP_SLUG_UNDERSCORE}}

# === Auth ===
SECRET_KEY=change-me-to-a-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === Redis / Celery ===
REDIS_URL=redis://localhost:6379/0

# === CORS ===
CORS_ORIGINS=http://localhost:3000

# === Email ===
EMAIL_BACKEND=console
RESEND_API_KEY=
EMAIL_FROM={{APP_DISPLAY_NAME}} <noreply@example.com>
FRONTEND_URL=http://localhost:3000

# === SMTP (alternative to Resend) ===
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_USE_TLS=true

# === Auth — Registration ===
# REQUIRE_EMAIL_VERIFICATION=true
# VERIFICATION_TOKEN_EXPIRE_HOURS=24
# PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# === Sentry ===
SENTRY_DSN=

# === Rate Limiting ===
RATE_LIMIT_PER_MINUTE=100

# === App ===
DEBUG=false
